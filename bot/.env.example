# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
ACCOUNT_LABEL=uganda-main

# BetPawa (Uganda)
BETPAWA_PHONE=+256xxxxxxxxx
BETPAWA_PASSWORD=your-password
# Or use email:
BETPAWA_EMAIL=your-email@example.com

# 22Bet (Uganda)
BET22_USERNAME=your-username
BET22_PASSWORD=your-password

# SportPesa (Uganda)
SPORTPESA_PHONE=+256xxxxxxxxx
SPORTPESA_PIN=your-pin

# Betway (Uganda)
BETWAY_EMAIL=your-email@example.com
BETWAY_PASSWORD=your-password

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Logging
LOG_LEVEL=info
NODE_ENV=production