# ─── Required ──────────────────────────────────────────────
# BetPawa credentials
BETPAWA_EMAIL=you@example.com
BETPAWA_PASSWORD=your-password

# Odds API (either name works)
THEODDSAPI_KEY=
# ODDS_API_KEY=

# ─── Optional ──────────────────────────────────────────────
# Supabase credentials are auto-detected from the Lovable Cloud
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY values. Override only
# if you want to point the bot at a different project.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

BETPAWA_URL=https://www.betpawa.co.tz

# Account label shown in dashboard
ACCOUNT_LABEL=primary

# Total bankroll the bot is allowed to deploy (informational)
TOTAL_INVESTMENT=100000

# Set to "false" to watch the browser, "true" for production
HEADLESS=true

# Identifier for this bot instance
AGENT_ID=primary